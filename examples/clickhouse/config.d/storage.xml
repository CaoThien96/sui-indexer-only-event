<clickhouse>
  <storage_configuration>
    <disks>
      <hot_disk>
        <path>/var/lib/clickhouse/hot/</path>
      </hot_disk>
      <cold_disk>
        <path>/var/lib/clickhouse/cold/</path>
      </cold_disk>
    </disks>
    <policies>
      <hot_cold>
        <volumes>
          <hot>
            <disk>hot_disk</disk>
          </hot>
          <cold>
            <disk>cold_disk</disk>
          </cold>
        </volumes>
        <move_factor>0.1</move_factor>
      </hot_cold>
    </policies>
  </storage_configuration>
</clickhouse>
