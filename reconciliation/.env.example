DATABASE_URL=postgres://postgres:postgres@localhost:5432/sui_indexer
FULLNODE_URL=https://fullnode.mainnet.sui.io:443

# MoveEventType filter — use fullnode canonical casing (matches stored event_type)
RECON_MOVE_EVENT_TYPE=0x1eabed72c53feb3805120a081dc15963c204dc8d091542592abaf7a35689b2fb::pool::SwapEvent

# Window: [now - END_HOURS_AGO - WINDOW_HOURS, now - END_HOURS_AGO]
RECON_WINDOW_HOURS=1
RECON_WINDOW_END_HOURS_AGO=2

# Phase 1: absolute count diff allowed (secondary check)
RECON_COUNT_TOLERANCE=100

# Phase 2: allowed missing/extra keys (0 = strict key match)
RECON_KEY_TOLERANCE=0

# Max keys to print per missing/extra sample list
RECON_MAX_KEY_SAMPLES=20
