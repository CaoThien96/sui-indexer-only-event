DATABASE_URL=postgres://postgres:postgres@localhost:5432/sui_indexer
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=sui_indexer
EVENT_TYPE_PREFIXES=0x1eabed72c53feb3805120a081dc15963c204dc8d091542592abaf7a35689b2fb::,0x91bfbc386a41afcfd9b2533058d7e915a1d3829089cc268ff4333d54d6339ca1::

# Optional: Prometheus (default http://0.0.0.0:9184/metrics — framework built-ins + app counters)
# METRICS_ADDRESS=0.0.0.0:9184
# METRICS_PREFIX=simple_sui_indexer

# Same credentials as examples/clickhouse/.env
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me

# Optional: Telegram alerts when processor fails (e.g. missing event binding)
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=-1001234567890
# TELEGRAM_NOTIFY_COOLDOWN_SECS=300

# --- Snip bot (integrated reactor) ---
# BOT_ENABLED=true
# BOT_LOG_ONLY=true          # suppress indexer/framework logs; keep bot snip/sell/LP only
#
# Manual bot tests (real on-chain txs; indexer not required):
#   cargo run --release --bin bot-snip -- --pool 0x... --token 0x...::coin::COIN --dex cetus
#   cargo run --release --bin bot-sell -- --pool 0x... --token 0x...::coin::COIN --amount 1000000000
# Add --dry-run to simulate PTB without submitting (uses sui_dryRunTransactionBlock)
# Legacy alias: bot-test-snip (supports --valora shorthand)
#   cargo run --release --bin bot-test-snip -- --valora
# MAIN_RPC=https://fullnode.mainnet.sui.io:443
# FALLBACK_RPCS=
# VAULT_PATH=./vault.json
# MAIN_SEED_PHRASE="word1 word2 ..."   # quote if the phrase contains spaces
# SNIP_BUY_AMOUNT=10000000
# SNIP_DELAY_MS_MIN=5000
# SNIP_DELAY_MS_MAX=10000
# SNIP_LP_WAIT_MS=60000
# MIN_POOL_RESERVE_SUI=10000000000
# REMOVE_RESERVE_THRESHOLD=2000000000
# SELL_BUY_THRESHOLD=500000000
# SELL_TX_REQUEST_TYPE=WaitForEffectsCert
# SELL now uses address-balance gas for lower submit latency.
# Ensure VAULT address balance has enough SUI for gas.
# BLACKLIST_TOKEN=
# BOT_PROCESSED_SWAPS_TTL_DAYS=7
# BOT_CLEANUP_INTERVAL_SECS=86400

# Snip vault (optional — atomic buy+LP and vault sell; requires Sui CLI v1.63+)
# When enabled, snip tries vault first; sell always uses the on-chain vault Bag.
# SNIP_VAULT_FALLBACK_AGG=true (default) retries snip via agg_swap + LP if vault tx fails.
# USE_SNIP_VAULT=true
# SNIP_VAULT_PACKAGE=0x...
# SNIP_VAULT_OBJECT_ID=0x...
# SNIP_VAULT_GAS_BUDGET=500000000
# SNIP_VAULT_FALLBACK_AGG=true
#
# Migrate wallet tokens into vault Bag: cargo run --release --bin vault-deposit -- --token 0x...::coin::COIN
# Withdraw vault tokens to wallet: cargo run --release --bin vault-withdraw -- --token 0x...::coin::COIN
# Manual top-up vault address balance for sell gas:
#   scripts/send_funds_to_address_balance.sh <vault_address> <amount_mist> [coin_object_id]

# One-time migration from bot-snip Postgres (run: cargo run --bin migrate-removed-tokens)
# BOT_SNIP_DATABASE_URL=postgres://user:pass@localhost:5432/bot_snip
