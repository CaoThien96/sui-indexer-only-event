CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=sui_indexer
RPC_PORT=9000
RUST_LOG=info

# Log warn when a request exceeds this latency (milliseconds)
RPC_SLOW_WARN_MS=500

# Set to 1 to force FINAL on reads (slower; only if you see duplicate rows before merge)
# CLICKHOUSE_QUERY_FINAL=0

# Same credentials as examples/clickhouse/.env
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me
