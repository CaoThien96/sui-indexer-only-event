# Postgres (local infra + indexer)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sui_indexer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Keep in sync with POSTGRES_* above. Prefer POSTGRES_* vars when set (handles @ in password).
# If you set DATABASE_URL manually, URL-encode special chars (@ → %40).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sui_indexer

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=sui-token-indexer
# Set false when restarting the indexer often on local Kafka (avoids OutOfOrderSequenceNumber)
# KAFKA_ENABLE_IDEMPOTENCE=false
METRICS_ADDRESS=0.0.0.0:9184

# Week 8–9 processors (see docs/plans/week-08-09-processors.md)
PROCESSOR_METRICS_ADDRESS=0.0.0.0:9185
CATALOG_CONSUMER_GROUP=catalog-worker
SWAP_NORMALIZER_CONSUMER_GROUP=swap-normalizer
# backfill: earliest; steady-state prod: latest
KAFKA_AUTO_OFFSET_RESET=earliest

# Week 10–12 metrics layer (see docs/plans/week-10-12-ohlc-volume.md)
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=postgres
TIMESCALE_DB=sui_metrics
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
# Host port for TimescaleDB (container listens on 5432; docker-compose maps 5433→5432).
TIMESCALE_URL=postgres://postgres:postgres@localhost:5433/sui_metrics
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
VOLUME_ENGINE_CONSUMER_GROUP=volume-engine
OHLC_AGGREGATOR_CONSUMER_GROUP=ohlc-aggregator
VOLUME_METRICS_ADDRESS=0.0.0.0:9186
OHLC_METRICS_ADDRESS=0.0.0.0:9187

# Week 13–15 API + ClickHouse (see docs/plans/week-13-15-api-clickhouse.md)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=sui_metrics
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
API_PORT=8081
API_METRICS_ADDRESS=0.0.0.0:9188
ROLLOFF_METRICS_ADDRESS=0.0.0.0:9189
ROLLOFF_BATCH_SIZE=10000
ROLLOFF_INTERVAL_SECS=3600
HOT_STORAGE_DAYS=30

# api-service CORS (comma-separated origins for apps/web dev server)
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Week 7 runtime tuning (see docs/plans/week-07-hardening.md)
# steady = gRPC at tip (default); backfill = HTTPS catch-up (higher ingest concurrency)
# INDEXER_RUNTIME_MODE=steady
# COLLECT_INTERVAL_MS=300
# INGEST_CONCURRENCY_MAX=500
# INGEST_CONCURRENCY=200
# SUBSCRIBER_CHANNEL_SIZE=
# PIPELINE_DEPTH=2
# PROCESSOR_FANOUT_MAX=
# DB_CONNECTION_POOL_SIZE=15

# Mainnet ingestion — HTTPS backfill + gRPC steady state (GCS deferred; see week-07 runbook)
REMOTE_STORE_URL=https://checkpoints.mainnet.sui.io
STREAMING_URL=https://fullnode.mainnet.sui.io:443
# Optional dev override — use a recent mainnet checkpoint (see week-03-04 runbook)
# FIRST_CHECKPOINT=200000000

# Future: GCS backfill when budget allows (>30d history without HTTPS rate limits)
# REMOTE_STORE_GCS=mysten-mainnet-checkpoints-use4
# GOOGLE_APPLICATION_CREDENTIALS=...
