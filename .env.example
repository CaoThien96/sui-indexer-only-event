# Postgres (local infra + indexer)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sui_indexer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Keep in sync with POSTGRES_* above (dotenv does not expand nested vars).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sui_indexer

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=sui-token-indexer
# Set false when restarting the indexer often on local Kafka (avoids OutOfOrderSequenceNumber)
# KAFKA_ENABLE_IDEMPOTENCE=false
METRICS_ADDRESS=0.0.0.0:9184

# Mainnet ingestion (Week 3-4)
REMOTE_STORE_URL=https://checkpoints.mainnet.sui.io
STREAMING_URL=https://fullnode.mainnet.sui.io:443
# Optional dev override — use a recent mainnet checkpoint (see week-03-04 runbook)
# FIRST_CHECKPOINT=200000000

# Week 7+ GCS backfill (not used this sprint)
# REMOTE_STORE_GCS=mysten-mainnet-checkpoints-use4
# GOOGLE_APPLICATION_CREDENTIALS=...
